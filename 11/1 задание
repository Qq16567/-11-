print("=== Задача 1 ===")
solutions = []
for n in range(1, 13):
    for k in range(1, 13):
        for m in range(1, 12):
            if 28 * n + 30 * k + 31 * m == 365:
                solutions.append((n, k, m))
# Сортируем по возрастанию n (по условию)
solutions.sort()
for n, k, m in solutions:
    print(f"n={n}, k={k}, m={m}")
